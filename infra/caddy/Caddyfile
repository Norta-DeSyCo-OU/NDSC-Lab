# Caddyfile — production fronted by Cloudflare; trust CF as origin proxy.
# In production: replace `:80` with `your.domain` and set CF to "Full (strict)".
# Cloudflare IP allowlist is enforced at the host firewall (see ops/runbooks/firewall.md).

{
  email admin@example.invalid
  servers {
    trusted_proxies static private_ranges
  }
}

:80 {
  encode zstd gzip

  # Allow large uploads (video originals can be many GB before transcoding).
  request_body {
    max_size 100GB
  }

  # Strict headers; CSP nonces should come from app responses if app emits them.
  header {
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "interest-cohort=()"
    # HSTS only after TLS is live in front:
    # Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    -Server
  }

  handle_path /api/* {
    reverse_proxy api:8000
  }

  handle /healthz {
    reverse_proxy api:8000
  }

  handle /.well-known/* {
    reverse_proxy api:8000
  }

  handle {
    reverse_proxy web:3000
  }
}
