# Shared edge proxy for all three products. One Caddy on :80/:443,
# automatic Let's Encrypt TLS per domain.
#
#   lab.nortadesyco.xyz    -> NDSC Lab portal    (web + api in THIS compose)
#   nortadesyco.xyz        -> Norta DeSyCo site  (nortadesyco-web, via web-edge net)
#   englishwithsoheila.net -> EnglishWithSoheila (englishwithsoheila-web, web-edge)
#
# The two marketing-site containers are reached over the external `web-edge`
# Docker network (see the compose files of all three projects).

{
	email sowelu94@gmail.com
	servers {
		trusted_proxies static private_ranges
	}
}

(security_headers) {
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "interest-cohort=()"
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
		-Server
	}
}

# ---- NDSC Lab portal -------------------------------------------------------
lab.nortadesyco.xyz {
	encode zstd gzip
	import security_headers

	# Video originals can be many GB before transcoding.
	request_body {
		max_size 100GB
	}

	handle_path /api/* {
		reverse_proxy api:8000
	}
	handle /healthz {
		reverse_proxy api:8000
	}
	handle /.well-known/* {
		reverse_proxy api:8000
	}
	handle {
		reverse_proxy web:3000
	}
}

# ---- Norta DeSyCo marketing site ------------------------------------------
nortadesyco.xyz {
	encode zstd gzip
	reverse_proxy nortadesyco-web:8080
}

www.nortadesyco.xyz {
	redir https://nortadesyco.xyz{uri} permanent
}

# ---- EnglishWithSoheila ---------------------------------------------------
